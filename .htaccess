############################################
# Core settings
############################################

RewriteEngine On
RewriteBase /

# HTTPS Redirect (först — innan alla andra regler)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Prioritera alltid PHP före HTML
DirectoryIndex index.php index.htm index.html

# Inaktivera directory listing
Options -Indexes

# Följ symboliska länkar
Options +FollowSymLinks


############################################
# URL Rewriting - Rena URLer
############################################

# /robots.txt -> /seo/robots.php
RewriteRule ^robots\.txt$ seo/robots.php [L]

# /admin -> /cms/admin.php
RewriteRule ^admin/?$ cms/admin.php [L]

# /dashboard -> /cms/dashboard.php
RewriteRule ^dashboard/?$ cms/dashboard.php [L]

# /media -> /cms/media.php
RewriteRule ^media/?$ cms/media.php [L]

# /setup -> /setup.php
RewriteRule ^setup/?$ setup.php [L]

# /super-admin -> /cms/super-admin.php
RewriteRule ^super-admin/?$ cms/super-admin.php [L]

# /api/super -> /cms/api-super.php
RewriteRule ^api/super/?$ cms/api-super.php [QSA,L]

# /bosse-health -> /bosse-health.php
RewriteRule ^bosse-health/?$ bosse-health.php [L]

# /kontakt -> /pages/kontakt.php
RewriteRule ^kontakt/?$ pages/kontakt.php [L]

# /cookies -> /pages/cookies.php
RewriteRule ^cookies/?$ pages/cookies.php [L]

# /integritetspolicy -> /pages/integritetspolicy.php
RewriteRule ^integritetspolicy/?$ pages/integritetspolicy.php [L]

# /projects -> /cms/projects/index.php (legacy)
RewriteRule ^projects/?$ cms/projects/index.php [L]

# /projects/new -> /cms/projects/new.php (legacy)
RewriteRule ^projects/new/?$ cms/projects/new.php [QSA,L]

# /projects/edit -> /cms/projects/edit.php (legacy)
RewriteRule ^projects/edit/?$ cms/projects/edit.php [QSA,L]

# /inlagg-admin -> /cms/projects/index.php
RewriteRule ^inlagg-admin/?$ cms/projects/index.php [L]

# /inlagg-admin/ny -> /cms/projects/new.php
RewriteRule ^inlagg-admin/ny/?$ cms/projects/new.php [QSA,L]

# /inlagg-admin/redigera -> /cms/projects/edit.php
RewriteRule ^inlagg-admin/redigera/?$ cms/projects/edit.php [QSA,L]

# /tickets -> /cms/tickets.php
RewriteRule ^tickets/?$ cms/tickets.php [L]

# /tickets/{id} -> /cms/ticket-single.php?id={id}
RewriteRule ^tickets/(\d+)/?$ cms/ticket-single.php?id=$1 [QSA,L]

# /inlagg -> /pages/inlagg.php
RewriteRule ^inlagg/?$ pages/inlagg.php [L]

# /inlagg/{slug} -> /pages/inlagg-single.php?slug={slug}
RewriteRule ^inlagg/([a-z0-9-]+)/?$ pages/inlagg-single.php?slug=$1 [QSA,L]

# /categories -> /cms/categories.php
RewriteRule ^categories/?$ cms/categories.php [L]

# BEGIN BOSSE CUSTOM ROUTES
# Auto-generated from cms/extensions/routes.php and categories.php
# Regenerated on update and when categories change — do not edit manually
# END BOSSE CUSTOM ROUTES

# Ta bort .php — kolla pages/ först, sedan rot
RewriteCond %{DOCUMENT_ROOT}/pages/$1.php -f
RewriteRule ^(.+?)/?$ pages/$1.php [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L,QSA]

# Front controller — dynamiska routes via router.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /router.php [L]


############################################
# Cache-strategi: prod men alltid uppdaterad
############################################

<IfModule mod_headers.c>

    # PHP & HTML – aldrig cache i browser
    <FilesMatch "\.(php|html)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
    </FilesMatch>

    # CSS & JS – cache med revalidering (immutable bryter @import-filer utan ?v=)
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=86400, must-revalidate"
    </FilesMatch>

    # Bilder – 30 dagars cache
    <FilesMatch "\.(jpg|jpeg|png|webp|svg|gif|ico)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>

</IfModule>


############################################
# Säkerhetsheaders
############################################

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    # CSP is set dynamically from PHP (bootstrap.php -> security/csp.php)
    # This allows nonce-based script-src instead of unsafe-inline

    # Remove server signature
    Header unset Server
    Header unset X-Powered-By
</IfModule>


############################################
# Skydda känsliga filer
############################################

<FilesMatch "^(\.env|\.git|\.htaccess|config\.php|config\.php\.bak|composer\.(json|lock)|update-state\.json|backup-meta\.json)">
    Require all denied
</FilesMatch>

# Skydda data/backups och data/tmp
RewriteRule ^data/(backups|tmp)/ - [F,L]

# Förhindra PHP-exekvering i uploads (se uploads/.htaccess)
# OBS: <Directory> och php_value/php_flag är inte tillåtna i .htaccess på PHP-FPM-servrar
# PHP-inställningar hanteras via .user.ini


############################################
# Gzip Compression
############################################

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>


############################################
# Custom Error Pages
############################################

ErrorDocument 404 /pages/errors/404.php
ErrorDocument 403 /pages/errors/403.php
ErrorDocument 500 /pages/errors/500.php
